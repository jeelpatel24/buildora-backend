    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Homeowner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 (created) or 409 (already exists)', function () {",
                  "    pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "var json = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "    pm.test('Response has token', function () {",
                  "        pm.expect(json).to.have.property('token');",
                  "    });",
                  "    pm.test('User role is Homeowner', function () {",
                  "        pm.expect(json.user.role).to.eql('Homeowner');",
                  "    });",
                  "}",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('homeowner_token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"Homeowner\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Public route. Register a new Homeowner. Returns 409 on re-runs (email already exists) — both are valid outcomes."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"User registered successfully\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"userId\": 2,\n    \"name\": \"Alice Johnson\",\n    \"email\": \"alice@example.com\",\n    \"role\": \"Homeowner\",\n    \"isVerified\": false\n  }\n}"
            },
            {
              "name": "409 Conflict - Email Already Exists",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": \"Email already registered\"\n}"
            }
          ]
        },
