{
  "info": {
    "name": "Buildora API",
    "description": "Complete API collection for Buildora - Home Renovation Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "homeowner_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "contractor_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
