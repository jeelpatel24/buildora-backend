{
  "info": {
    "_postman_id": "buildora-api-collection-v1",
    "name": "Buildora API",
    "description": "Complete API collection for Buildora - Home Renovation Project Matching Platform.\n\n**Live Base URL:** https://web-production-afb0.up.railway.app\n\n**How to use:**\n1. Run 'Register Homeowner' → copy the token → paste into the `homeowner_token` variable\n2. Run 'Register Contractor' → copy the token → paste into the `contractor_token` variable\n3. Run 'Login Admin' → copy the token → paste into the `admin_token` variable\n4. All protected routes will now work automatically\n\n**Default Admin:** admin@buildora.com / admin123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://web-production-afb0.up.railway.app",
      "type": "string"
    },
    {
      "key": "homeowner_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "contractor_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
