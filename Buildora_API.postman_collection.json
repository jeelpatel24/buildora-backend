              "host": ["{{base_url}}"],
              "path": ["api", "projects", "my"]
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{contractor_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/projects/1",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "1"]
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{homeowner_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Kitchen Renovation - Updated\",\n  \"description\": \"Updated description with more details\",\n  \"budget_min\": 18000,\n  \"budget_max\": 28000,\n  \"location\": \"Toronto, ON\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/projects/1",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "1"]
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{homeowner_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/projects/1",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "1"]
            }
          }
        }
      ]
    },
