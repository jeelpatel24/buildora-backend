# Buildora Backend - Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Railway PostgreSQL Database
# Get this from Railway Dashboard → PostgreSQL → Variables → DATABASE_URL
# Example: postgresql://postgres:abc123xyz@containers-us-west-123.railway.app:5432/railway
DATABASE_URL=your-railway-database-url-here

# JWT Secret for Authentication
# IMPORTANT: Change this to a long random string in production!
# You can generate one at: https://randomkeygen.com/
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==============================================================================
# SETUP INSTRUCTIONS:
# ==============================================================================
# 1. Create Railway account at https://railway.app/
# 2. Create new project → Provision PostgreSQL
# 3. Click PostgreSQL service → Variables tab
# 4. Copy the DATABASE_URL value
# 5. Rename this file from .env.example to .env
# 6. Paste your Railway DATABASE_URL above
# 7. Change the JWT_SECRET to a random string
# 8. Run: npm run init-db
# 9. Run: npm run dev
# ==============================================================================

# Optional: Uncomment if you want to customize
# LOG_LEVEL=info
# MAX_POOL_SIZE=10
